# Copy this file to .env on the Oracle VM and replace every placeholder value.
# Do not commit the real .env file.

POSTGRES_DB=bob
POSTGRES_USER=bob
POSTGRES_PASSWORD=replace-with-a-strong-database-password

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/bob
SPRING_DATASOURCE_USERNAME=bob
SPRING_DATASOURCE_PASSWORD=replace-with-the-same-database-password

BOB_AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-characters
BOB_AUTH_JWT_EXPIRATION_MINUTES=480
BOB_APP_VERSION=0.1.0

BOB_AI_ENABLED=false
BOB_AI_MODEL=
OPENAI_API_KEY=
BOB_AI_DEBUG_RESPONSE_SHAPE=false

SERVER_PORT=8080
BACKEND_PORT=8080
