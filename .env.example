POSTGRES_DB=bob
POSTGRES_USER=bob
POSTGRES_PASSWORD=bob
POSTGRES_PORT=5432

DATABASE_URL=postgresql://bob:bob@localhost:5432/bob

BOB_AUTH_JWT_SECRET=local-development-secret-change-me-please-32
BOB_AUTH_JWT_EXPIRATION_MINUTES=480

# AI is off by default for local setup and CI.
# To enable Bob read generation, set all three values in the backend environment.
# Never commit a real OpenAI API key.
BOB_AI_ENABLED=false
BOB_AI_MODEL=
OPENAI_API_KEY=
